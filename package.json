{
  "name": "assetflow",
  "version": "1.0.0",
  "private": true,
  "workspaces": ["backend", "frontend"],
  "scripts": {
    "setup": "node scripts/setup.js",
    "dev": "concurrently -n backend,frontend -c cyan,magenta \"yarn workspace backend dev\" \"yarn workspace frontend dev\"",
    "build": "yarn workspace frontend build",
    "start": "yarn workspace backend start"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
