{
  "name": "assetflow",
  "version": "1.0.0",
  "description": "Probabilistic multi-agent asset prediction platform",
  "private": true,
  "scripts": {
    "install:all": "yarn && cd backend && yarn && cd ../frontend && yarn",
    "dev": "concurrently \"yarn run dev:backend\" \"yarn run dev:frontend\"",
    "dev:backend": "cd backend && yarn dev",
    "dev:frontend": "cd frontend && yarn dev",
    "build": "cd frontend && npm run build",
    "start": "cd backend && npm start",
    "setup": "node scripts/setup.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
